# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Application Settings
APP_NAME=TelegramCommunicationBot
WELCOME_MESSAGE=Welcome!

# Admin Configuration
ADMIN_GROUP_ID=-1001234567890
ADMIN_USER_IDS=123456789,987654321

# Bot Behavior Settings
DELETE_TOPIC_AS_FOREVER_BAN=false
DELETE_USER_MESSAGE_ON_CLEAR_CMD=false
MESSAGE_INTERVAL=5

# CAPTCHA Settings
CAPTCHA_ENABLED=false

# Database Settings
DATABASE_PATH=./data/bot.db

# Server Settings (for webhook mode)
PORT=8090
# WEBHOOK_URL=https://yourdomain.com/webhook  # Leave empty or comment out for polling mode

# Debug Settings
DEBUG=true